<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginTop="80dp"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adicionar Talhão"
        android:textSize="24sp"
        android:layout_marginBottom="24dp"
        android:layout_gravity="center_horizontal"
        android:textColor="@color/black"
        android:textStyle="bold"
        />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <AutoCompleteTextView
            android:id="@+id/autoCompleteLavouraTalhao"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="lavoura" />
    </com.google.android.material.textfield.TextInputLayout>

    <EditText
        android:id="@+id/input_nome_talhao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome do talhão"
        android:textSize="24sp"
        android:layout_marginTop="16dp"
    />

    <EditText
        android:id="@+id/input_preco"
        android:inputType="number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Preço do talhão"
        android:textSize="24sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/button_salvar_Lavoura"
        android:layout_width="match_parent"
        android:layout_height="80sp"
        android:text="salvar"
        android:textSize="20sp" />

</LinearLayout>